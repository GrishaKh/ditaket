# ──────────────────────────────────────────────────────────────────────
# Database — Neon Postgres (via Vercel Marketplace integration)
# ──────────────────────────────────────────────────────────────────────
DATABASE_URL=
# Optional unpooled URL for one-shot connections (drizzle-kit, migrations)
DATABASE_URL_UNPOOLED=
# Vercel legacy aliases (auto-set by Vercel Postgres → Neon migration):
POSTGRES_URL=
POSTGRES_URL_NON_POOLING=

# ──────────────────────────────────────────────────────────────────────
# Rate-limit cache — Upstash Redis (via Vercel Marketplace)
# ──────────────────────────────────────────────────────────────────────
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=
# Vercel legacy aliases:
KV_REST_API_URL=
KV_REST_API_TOKEN=

# ──────────────────────────────────────────────────────────────────────
# File storage — Vercel Blob (optional report attachments)
# ──────────────────────────────────────────────────────────────────────
BLOB_READ_WRITE_TOKEN=

# ──────────────────────────────────────────────────────────────────────
# Anti-spam — Cloudflare Turnstile
# https://dash.cloudflare.com/?to=/:account/turnstile
# ──────────────────────────────────────────────────────────────────────
NEXT_PUBLIC_TURNSTILE_SITE_KEY=
TURNSTILE_SECRET_KEY=

# ──────────────────────────────────────────────────────────────────────
# Admin auth (minimal v1; replace with real auth post-launch)
# ──────────────────────────────────────────────────────────────────────
ADMIN_PASSWORD=

# ──────────────────────────────────────────────────────────────────────
# Site
# ──────────────────────────────────────────────────────────────────────
NEXT_PUBLIC_SITE_URL=https://ditaket.vercel.app
NEXT_PUBLIC_DEFAULT_LOCALE=am
